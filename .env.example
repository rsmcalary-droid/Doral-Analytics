# ---------------------------------------------------------------------------
# Doral Analytics — environment variables
# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored and stays on your machine / in your host's secrets.
# ---------------------------------------------------------------------------

# Supabase (Project Settings → Data API / API Keys)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Public contact address — shown on the site and in the legal pages.
NEXT_PUBLIC_CONTACT_EMAIL=hello@doralanalytics.com

# Who can use the dashboard is managed in the `admins` table in Supabase
# (see SETUP.md) — add a teammate by inserting their email there. No env var.
